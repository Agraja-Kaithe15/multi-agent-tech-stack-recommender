# Required: https://aistudio.google.com/apikey (paste your full key; no quotes)
GOOGLE_API_KEY=
# Alternative name supported by the Gemini client:
# GEMINI_API_KEY=

# Default model IDs (override if Google renames preview models)
GEMINI_TEXT_MODEL=gemini-3-flash-preview
GEMINI_IMAGE_MODEL=gemini-3.1-flash-image-preview

# Optional: Tavily for web search instead of Google Search grounding (set USE_TAVILY_SEARCH=true)
USE_TAVILY_SEARCH=false
TAVILY_API_KEY=
